# Anthropic API key used by the personalization agent and context distillation.
ANTHROPIC_API_KEY=sk-ant-...

# Model used for drafting sequences and distilling product context.
# claude-sonnet-4-6 is a sensible balance of quality and cost for bulk drafting;
# swap to an Opus model for top-quality copy or a Haiku model for cheap, high-volume runs.
OUTBOUND_MODEL=claude-sonnet-4-6
